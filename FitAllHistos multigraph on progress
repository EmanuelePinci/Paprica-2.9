#include <TFile.h>
#include <TH1D.h>
#include <TCanvas.h>
#include <TSpectrum.h>
#include <TGraphErrors.h>
#include <TF1.h>
#include <TString.h>
#include <iostream>
#include <vector>
#include <algorithm>

void FitAllHistos()
{

    // we open the root file with all the histograms of the 64 SiPMs and we check if the file has been opened correctly, if not we print an error message and we exit the function
    TFile *fileIn = new TFile("/Users/Utente/Desktop/run_020.root", "READ");
    if (!fileIn || fileIn->IsZombie())
    {
        std::cerr << "ERRORE: Impossibile aprire il file di input run_020.root" << std::endl;
        return;
    }

    // now we create the output file where we will save the results of the fits and the graphs
    TFile *fileOut = new TFile("/Users/Utente/Desktop/SiPM_FitResults.root", "RECREATE");

    //Now we create a multigraph to plot all the graph in one canvas and a legend to identify the different SiPMs, we set the title of the multigraph and the axes labels
    TMultiGraph *mg = new TMultiGraph();
    mg->SetTitle("Media vs Numero Picco - Tutti i SiPM;Numero Picco;Media Carica [Units]");
    TLegend *leg = new TLegend(0.1, 0.1, 0.3, 0.9);

    for (int i_sipm = 64; i_sipm <= 127; ++i_sipm)  // riga 27







    // 3. since we need to fit all the histograms of the 64 SiPMs, we create a loop that goes from 64 to 127 (since the SiPMs are numbered from 64 to 127) and for each SiPM we do the following steps:
    for (int i_sipm = 64; i_sipm <= 127; ++i_sipm)
    {

        // now we generate the name of the histogram for the current SiPM and we try to get it from the file, if we don't find it we print a warning and we skip to the next SiPM
        TString histoName = Form("charge_isipm%d", i_sipm);
        TH1D *h = (TH1D *)fileIn->Get(histoName);

        if (!h)
        {
            std::cerr << "Warning: Istogramma '" << histoName << "' non trovato. Salto al prossimo." << std::endl;
            continue;
        }
        // Nowe we rebin the histograms to have less bins and a smoother distribution for the fit
        h->Rebin(4);

        // this parte of the code is importante bacause we need to find the peaks of the histogram to fit them with a gaussian function, for this we use the TSpectrum class that allows us to find the peaks of a histogram and then we sort them in ascending order to select the first 5 peaks linked to photoelectrons
        TSpectrum *spec = new TSpectrum(50);
        int nPeaks = spec->Search(h, 15, "goff", 0.001);
        // her we check if we have found at least 2 peaks, if not we print a warning and we skip to the next SiPM, since we need at least 2 peaks to do the fit and to create the graph of media vs numero picco
        if (nPeaks < 2)
        {
            std::cerr << "Warning: TSpectrum non ha trovato abbastanza picchi in " << histoName << std::endl;
            delete spec;
            continue;
        }

        // Now with GetPosition we get the x positions of the peaks and we save them in a vector that we sort in ascending order to select the first 5 peaks linked to photoelectrons, if we have found more than 5 picchi, we fit only the first five peaks, otherwise we fit all the peaks that have been found.
        double *xPosRaw = spec->GetPositionX();
        std::vector<double> xPos(xPosRaw, xPosRaw + nPeaks);
        std::sort(xPos.begin(), xPos.end());

        // with vectors we save the results of the fits for each SiPM, in particular we save the mean values, the sigma values and their errors, and the number of the picco
        std::vector<double> means, meanErrors, sigmas, sigmaErrors, peakNumbers;

        // this function limits the number of peaks to fit to 5, if we have found more than 5 peaks, we fit only the first five peaks, otherwise we fit all the peaks that have been found.
        int peaksToFit = (nPeaks > 5) ? 5 : nPeaks;
        // we create a loop that goes from 0 to peaksToFit and for each peak we do the following steps: we create a gaussian function with a range of 10% around the x position of the peak, we set the initial parameters of the fit in a dynamic way based on the histogram content around the peak, we fit the histogram with the gaussian function and we save the results of the fit in the vectors that we have created before.
        for (int p = 0; p < peaksToFit; p++)
        {
            double xc = xPos[p];
            double range = xc * 0.10;

            if (range < 5.0)
                range = 20.0;
            if (xc > 1000)
                range = xc * 0.10;

            // with TString we create a unique name for each fit function to avoid conflicts
            TString funcName = Form("fit_sipm%d_peak%d", i_sipm, p);
            TF1 *fitFunc = new TF1(funcName, "gaus", xc - range, xc + range);

            // int binCenter takes as input the x position for the peak center and returns the numer of the bean of the histogram wiche contains the value of xc
            int binCenter = h->FindBin(xc);
            // with the doublepeakHeight we get the content of the bin center that should be close to the height of the peak
            double peakHeight = h->GetBinContent(binCenter);
            double sigma_guess = h->GetStdDev() / 5.0; // the first estimate of the sigma is arbitrary
// The first function SetParameter sets p0 = amplitude, p1 = mean, p2 = sigma, we set the initial parameters of the fit in a dynamic way based on the histogram content around the peak
            fitFunc->SetParameter(0, peakHeight);
            fitFunc->SetParameter(1, xc);
            fitFunc->SetParameter(2, sigma_guess);
            fitFunc->SetLineColor(kOrange + 1);

            // with this option the fit is printed in canvas for each simps
            h->Fit(fitFunc, "RQ+");

            means.push_back(fitFunc->GetParameter(1));
            meanErrors.push_back(fitFunc->GetParError(1));
            sigmas.push_back(fitFunc->GetParameter(2));
            sigmaErrors.push_back(fitFunc->GetParError(2));
            peakNumbers.push_back(p);
        }

        // 4. Scriviamo l'istogramma con i fit gaussiani salvati al suo interno nel file di output
        fileOut->cd();
        h->Write();

        // 5. Creiamo e fittiamo il grafico Media vs Numero Picco We create and fit the graph media vs number of peak but using multigraph root option in ordere to have all the graphs of the different SIMPs in the same canvas.

        if (means.size() > 1)
{
    TString graphName = Form("gain_graph_isipm%d", i_sipm);
    TGraphErrors *graph = new TGraphErrors(means.size(), peakNumbers.data(), means.data(), 0, meanErrors.data());

    graph->SetName(graphName);
    graph->SetTitle(Form("SiPM %d", i_sipm));
    graph->SetMarkerStyle(21);

    int color = (i_sipm - 64) % 64 + 1;
    graph->SetMarkerColor(color);
    graph->SetLineColor(color);

    TF1 *lineFit = new TF1(Form("lineFit_sipm%d", i_sipm), "pol1", 0, means.size() - 1);
    lineFit->SetLineColor(color);
    graph->Fit(lineFit, "RQ0");

    mg->Add(graph);
    leg->AddEntry(graph, Form("SiPM %d", i_sipm), "lp");

    fileOut->cd();
    graph->Write();
}

            //fare fuori dal ciclo for una nuova canvas e poi per ogni simps ho il grafic con tutte le rette senza dover usare same per ogni grafico, in questo modo è più facile confrontare i risultati dei diversi SiPMs e vedere se ci sono differenze significative tra di loro, inoltre si può aggiungere una legenda

    // Chiusura file
    fileOut->Close();
    fileIn->Close();

    std::cout << "\n===== ANALISI COMPLETATA =====" << std::endl;
    std::cout << "Tutti i fit e i grafici sono stati salvati nel file: SiPM_FitResults.root" << std::endl;
}
